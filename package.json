{
  "name": "sharemint",
  "version": "1.0.0",
  "description": "NSE/BSE Stock Analyzer — React + Node.js + Electron",
  "main": "main.js",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "build-react": "cd frontend && npm run build",
    "start": "electron .",
    "dev": "electron .",
    "build-win": "npm run build-react && electron-builder --win --x64",
    "build-portable": "npm run build-react && electron-builder --win portable"
  },
  "build": {
    "appId": "co.sharemint.app",
    "productName": "Share Mint",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/build/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Share Mint"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
